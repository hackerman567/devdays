{
  "name": "signify-ai",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "build": "npm run build --workspace=client",
    "vercel-build": "cd client && npm install && npm run build",
    "start": "npm run start --workspace=server"
  },
  "dependencies": {
    "groq-sdk": "^0.3.3"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
